@page
@model Time2Cook.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-icon">🍳</div>
        <h1>Welcome Back</h1>
        <p class="auth-subtitle">Log in to access your saved recipes.</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="auth-error">@Model.ErrorMessage</div>
        }

        <form method="post" asp-page-handler="" asp-route-returnUrl="@Model.ReturnUrl">
            <div class="auth-field">
                <label asp-for="Input.Email">Email Address</label>
                <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="Your password" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="auth-validation"></span>
            </div>

            <button type="submit" class="auth-btn">Log In</button>
        </form>

        <p class="auth-switch">
            Don't have an account? <a asp-page="/Register">Create one →</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
