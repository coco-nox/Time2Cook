<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pantry Pal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Time2Cook.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm">
            <div class="nav-container">
                <a class="navbar-brand" asp-page="/Index">🥘 Pantry Pal</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between w-100">
                    <ul class="navbar-nav nav-links">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active-link" : "")" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/SearchMeals" ? "active-link" : "")" asp-page="/SearchMeals">Search Meals</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/SavedRecipes" ? "active-link" : "")" asp-page="/SavedRecipes">
                                Saved Recipes
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav nav-auth">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-profile-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Profile" ? "active-link" : "")" asp-page="/Profile">
                                    <span class="nav-avatar">@User.Identity.Name![0].ToString().ToUpper()</span>
                                    My Profile
                                </a>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-page="/Logout" style="display:inline;">
                                    <button type="submit" class="nav-logout-btn">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Login" ? "active-link" : "")" asp-page="/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-register-btn" asp-page="/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <span class="footer-brand">🥘 Pantry Pal</span>
            <span>&copy; 2026 Pantry Pal &mdash; Eat better, spend less.</span>
            <a asp-page="/Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
