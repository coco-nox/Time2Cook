@page
@model Time2Cook.Pages.RegisterModel
@{
    ViewData["Title"] = "Create Account";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-icon">🍳</div>
        <h1>Create Account</h1>
        <p class="auth-subtitle">Join Time2Cook and start saving your favourite meals.</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="auth-error">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="auth-field">
                <label asp-for="Input.Email">Email Address</label>
                <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" class="form-control" placeholder="At least 6 characters" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="auth-validation"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Repeat your password" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="auth-validation"></span>
            </div>

            <button type="submit" class="auth-btn">Create Account</button>
        </form>

        <p class="auth-switch">
            Already have an account? <a asp-page="/Login">Log in →</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
